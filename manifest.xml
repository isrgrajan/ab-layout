<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
           xsi:type="TaskPaneApp"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

  <Id>ab-layout-isrgrajan-v1</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>AB Layout</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>

  <DisplayName DefaultValue="AB Layout"/>
  <Description DefaultValue="Advocate Benefit Layout for Indian Courts"/>

  <!-- Optional icon (safe even if missing) -->
  <IconUrl DefaultValue="https://isrgrajan.github.io/ab-layout/assets/icon-32.png"/>

  <Hosts>
    <Host Name="Document"/>
  </Hosts>

  <Requirements>
    <Sets DefaultMinVersion="1.3">
      <Set Name="WordApi"/>
    </Sets>
  </Requirements>

  <DefaultSettings>
    <SourceLocation DefaultValue="https://isrgrajan.github.io/ab-layout/web/taskpane.html"/>
  </DefaultSettings>

  <Permissions>ReadWriteDocument</Permissions>

</OfficeApp>
